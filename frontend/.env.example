# AWS API Gateway WebSocket endpoint for INFER messages
NIMBUS_WS_URL=wss://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/dev

# Room identifier for participant grouping and caption routing
NIMBUS_ROOM_ID=room-1

# AWS credentials (required for boto3/AWS SDK calls if used)
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
AWS_REGION=us-east-1
