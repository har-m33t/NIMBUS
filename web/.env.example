# Cognito configuration — get these from CloudFormation stack outputs
# Leave empty to use mock auth (localStorage) for local development
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REGION=us-west-2

# Cognito Hosted UI domain prefix (e.g. "nimbus-prod")
# Used for Google OAuth sign-in redirect
VITE_COGNITO_DOMAIN=

# OAuth redirect URI (defaults to {origin}/oauth/callback)
VITE_COGNITO_REDIRECT_URI=

# WebSocket API URL — get from CloudFormation stack outputs
VITE_NIMBUS_WS_URL=
